{
  "compilerOptions": {
    "lib": ["ESNext", "dom", "dom.iterable"],
    "noEmit": true,
    "allowJs": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true
  }
}
